# MongoDB Configuration
# Preferred variable (used by the app):
MONGO_URI=mongodb://localhost:27017/clinical_database
# Optional legacy alias:
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/clinical_database

# Server Configuration
PORT=3000
CORS_ORIGIN=*

# Authentication / JWT
JWT_SECRET=your-secure-jwt-secret
REFRESH_TOKEN_SECRET=your-refresh-token-secret

